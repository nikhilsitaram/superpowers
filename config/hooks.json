{
  "PreToolUse": [{
    "matcher": "*",
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/config/pretooluse-safe-commands.sh"
    }]
  }],
  "PostToolUse": [{
    "matcher": "AskUserQuestion",
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/config/post-tool-use-design-approval.sh"
    }]
  }],
  "PermissionRequest": [{
    "matcher": "Edit|Write",
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/config/permission-request-accept-edits.sh"
    }]
  }]
}
