{
  "skip_tests": {
    "type": "bool",
    "default": false,
    "description": "Skip test suite before committing",
    "used_by": ["pr-create"]
  },
  "review_mode": {
    "type": "enum",
    "values": ["automated", "deliberate"],
    "prompt_required": true,
    "description": "PR review mode (prompted each time unless explicitly set)",
    "used_by": ["pr-review"]
  },
  "skip_review": {
    "type": "bool",
    "default": false,
    "description": "Skip PR reviewer subagent dispatch",
    "used_by": ["pr-review"]
  },
  "merge_strategy": {
    "type": "enum",
    "values": ["squash", "rebase"],
    "default": "squash",
    "description": "Default merge strategy for standard PRs (integration branches and phase PRs retain auto-detected strategy)",
    "used_by": ["pr-merge"]
  },
  "workflow": {
    "type": "enum",
    "values": ["pr-create", "pr-merge", "plan-only"],
    "prompt_required": true,
    "description": "Post-orchestration workflow (prompted each time unless explicitly set)",
    "used_by": ["design", "orchestrate"]
  },
  "execution_mode": {
    "type": "enum",
    "values": ["subagents", "agent-teams"],
    "prompt_required": true,
    "description": "Execution mode for plan dispatch (prompted each time unless explicitly set)",
    "used_by": ["design", "orchestrate"]
  },
  "planner_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "opus",
    "description": "Model for draft-plan writer",
    "used_by": ["design"]
  },
  "task_implementer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "opus",
    "description": "Model for task execution in orchestrate",
    "used_by": ["orchestrate"]
  },
  "review_wait_minutes": {
    "type": "int",
    "default": 5,
    "description": "Poll timeout in minutes for external review bot comments (warm-up periods remain fixed)",
    "used_by": ["orchestrate", "pr-review"]
  },
  "re_review_threshold": {
    "type": "int",
    "default": 5,
    "description": "Issue count above which reviewer is re-dispatched after fixes",
    "used_by": ["design", "orchestrate", "design-review", "plan-review", "implementation-review"]
  },
  "design_reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "opus",
    "description": "Model for design review",
    "used_by": ["design", "design-review"]
  },
  "plan_reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "sonnet",
    "description": "Model for plan review",
    "used_by": ["design", "plan-review"]
  },
  "task_reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "sonnet",
    "description": "Model for per-task review in orchestrate",
    "used_by": ["orchestrate"]
  },
  "implementation_reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "sonnet",
    "description": "Model for cross-task implementation review",
    "used_by": ["orchestrate", "implementation-review"]
  },
  "pr_reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "opus",
    "description": "Model for PR review",
    "used_by": ["pr-review"]
  }
}
