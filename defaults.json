{
  "skip_tests": {
    "type": "bool",
    "default": false,
    "description": "Skip test suite before committing",
    "used_by": ["pr-create"]
  },
  "review_mode": {
    "type": "enum",
    "values": ["automated", "deliberate"],
    "default": "deliberate",
    "description": "Default PR review mode",
    "used_by": ["pr-review"]
  },
  "skip_review": {
    "type": "bool",
    "default": false,
    "description": "Skip fresh-eyes subagent review dispatch",
    "used_by": ["pr-review"]
  },
  "merge_strategy": {
    "type": "enum",
    "values": ["squash", "rebase"],
    "default": "squash",
    "description": "Default merge strategy for standard PRs (integration branches and phase PRs retain auto-detected strategy)",
    "used_by": ["pr-merge"]
  },
  "workflow": {
    "type": "enum",
    "values": ["pr-create", "pr-merge", "plan-only"],
    "default": "pr-create",
    "description": "Default post-orchestration workflow",
    "used_by": ["design", "orchestrate"]
  },
  "execution_mode": {
    "type": "enum",
    "values": ["subagents", "agent-teams"],
    "default": "subagents",
    "description": "Default execution mode for plan dispatch",
    "used_by": ["design", "orchestrate"]
  },
  "implementer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "opus",
    "description": "Model for task implementers and draft-plan dispatch",
    "used_by": ["design", "orchestrate"]
  },
  "review_wait_minutes": {
    "type": "int",
    "default": 10,
    "description": "Poll timeout in minutes for external review bot comments (warm-up periods remain fixed)",
    "used_by": ["orchestrate", "pr-review"]
  },
  "re_review_threshold": {
    "type": "int",
    "default": 5,
    "description": "Issue count above which reviewer is re-dispatched after fixes",
    "used_by": ["design", "orchestrate", "design-review", "plan-review", "implementation-review"]
  },
  "reviewer_model": {
    "type": "enum",
    "values": ["opus", "sonnet", "haiku"],
    "default": "sonnet",
    "description": "Model for all review dispatches and fix-cycle agents",
    "used_by": ["design", "orchestrate", "design-review", "plan-review", "implementation-review", "pr-review"]
  },
  "bot_poll_timeout_minutes": {
    "type": "int",
    "default": 10,
    "description": "Maximum minutes to wait for external bot reviews before proceeding",
    "used_by": ["pr-review"]
  }
}
