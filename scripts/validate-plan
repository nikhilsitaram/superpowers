#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  validate-plan --schema <plan.json>
  validate-plan --render <plan.json>
  validate-plan --update-status <plan.json> --task <ID> --status <STATUS>
  validate-plan --update-status <plan.json> --phase <LETTER> --status <STATUS>
  validate-plan --update-status <plan.json> --plan --status <STATUS>
  validate-plan --criteria <plan.json> --task <ID>
  validate-plan --criteria <plan.json> --phase <LETTER>
  validate-plan --criteria <plan.json> --plan
USAGE
  exit 1
}

ERRORS=()
err() { ERRORS+=("$1"); }

find_timeout_cmd() {
  if command -v timeout >/dev/null 2>&1; then
    echo "timeout"
  elif command -v gtimeout >/dev/null 2>&1; then
    echo "gtimeout"
  else
    echo ""
  fi
}

do_schema() {
  local plan_json="$1"
  local plan_dir
  plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"

  local json
  json=$(cat "$plan_json")

  local schema status goal architecture tech_stack
  schema=$(echo "$json" | jq -r '.schema // empty')
  status=$(echo "$json" | jq -r '.status // empty')
  goal=$(echo "$json" | jq -r '.goal // empty')
  architecture=$(echo "$json" | jq -r '.architecture // empty')
  tech_stack=$(echo "$json" | jq -r '.tech_stack // empty')

  [[ -z "$schema" ]] && err "ERROR: missing_field: schema"
  [[ -z "$status" ]] && err "ERROR: missing_field: status"
  [[ -z "$goal" ]] && err "ERROR: missing_field: goal"
  [[ -z "$architecture" ]] && err "ERROR: missing_field: architecture"
  [[ -z "$tech_stack" ]] && err "ERROR: missing_field: tech_stack"

  if [[ -n "$status" ]]; then
    case "$status" in
      "Not Yet Started"|"In Development"|"Complete") ;;
      *) err "ERROR: invalid_plan_status: '$status' (expected: Not Yet Started, In Development, or Complete)" ;;
    esac
  fi

  local plan_criteria_count
  plan_criteria_count=$(echo "$json" | jq '(.success_criteria // []) | length')
  for ((i=0; i<plan_criteria_count; i++)); do
    local run expect_exit expect_output
    run=$(echo "$json" | jq -r ".success_criteria[$i].run // empty")
    expect_exit=$(echo "$json" | jq -r ".success_criteria[$i].expect_exit // empty")
    expect_output=$(echo "$json" | jq -r ".success_criteria[$i].expect_output // empty")

    [[ -z "$run" ]] && err "ERROR: empty_run: plan success_criteria[$i]"
    [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: plan success_criteria[$i] has neither expect_exit nor expect_output"
  done

  local phase_count
  phase_count=$(echo "$json" | jq '(.phases // []) | length')
  [[ "$phase_count" -eq 0 ]] && err "ERROR: empty_phases: plan must have at least one phase"

  local all_task_ids=()
  local all_create_paths=()
  local seen_phase_letters=""

  for ((p=0; p<phase_count; p++)); do
    local letter name phase_status rationale
    letter=$(echo "$json" | jq -r ".phases[$p].letter // empty")
    name=$(echo "$json" | jq -r ".phases[$p].name // empty")
    phase_status=$(echo "$json" | jq -r ".phases[$p].status // empty")
    rationale=$(echo "$json" | jq -r ".phases[$p].rationale // empty")

    [[ -z "$letter" ]] && err "ERROR: missing_field: phases[$p].letter"
    [[ -z "$name" ]] && err "ERROR: missing_field: phases[$p].name"
    [[ -z "$phase_status" ]] && err "ERROR: missing_field: phases[$p].status"
    [[ -z "$rationale" ]] && err "ERROR: missing_field: phases[$p].rationale"

    if [[ -n "$letter" ]]; then
      if [[ ! "$letter" =~ ^[A-Z]$ ]]; then
        err "ERROR: invalid_phase_letter_format: phases[$p].letter='$letter' must be a single uppercase A-Z character"
      fi
      if [[ " $seen_phase_letters " == *" $letter "* ]]; then
        err "ERROR: duplicate_phase_letter: phase letter '$letter' appears more than once"
      fi
      seen_phase_letters="$seen_phase_letters $letter"
    fi

    if [[ -n "$phase_status" ]]; then
      case "$phase_status" in
        "Not Started"|"In Progress") ;;
        Complete\ \(20[0-9][0-9]-[0-1][0-9]-[0-3][0-9]\)) ;;
        *) err "ERROR: invalid_phase_status: phases[$p].status='$phase_status' (expected: Not Started, In Progress, or Complete (YYYY-MM-DD))" ;;
      esac
    fi

    local phase_criteria_count
    phase_criteria_count=$(echo "$json" | jq "(.phases[$p].success_criteria // []) | length")
    for ((c=0; c<phase_criteria_count; c++)); do
      local run expect_exit expect_output
      run=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].run // empty")
      expect_exit=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].expect_exit // empty")
      expect_output=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].expect_output // empty")

      [[ -z "$run" ]] && err "ERROR: empty_run: phase $letter success_criteria[$c]"
      [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: phase $letter success_criteria[$c] has neither expect_exit nor expect_output"
    done

    local letter_lower
    letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')
    local phase_dir="phase-$letter_lower"
    if [[ ! -f "$plan_dir/$phase_dir/completion.md" ]]; then
      err "ERROR: missing_completion_file: $phase_dir/completion.md"
    fi

    local task_count
    task_count=$(echo "$json" | jq "(.phases[$p].tasks // []) | length")

    for ((t=0; t<task_count; t++)); do
      local id task_name task_status depends_on verification done_when
      id=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id // empty")
      task_name=$(echo "$json" | jq -r ".phases[$p].tasks[$t].name // empty")
      task_status=$(echo "$json" | jq -r ".phases[$p].tasks[$t].status // empty")
      verification=$(echo "$json" | jq -r ".phases[$p].tasks[$t].verification // empty")
      done_when=$(echo "$json" | jq -r ".phases[$p].tasks[$t].done_when // empty")

      [[ -z "$id" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].id"
      [[ -z "$task_name" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].name"
      [[ -z "$task_status" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].status"
      [[ -z "$verification" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].verification"
      [[ -z "$done_when" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].done_when"

      if [[ -n "$id" ]]; then
        if [[ ${#all_task_ids[@]} -gt 0 ]]; then
          for existing_id in "${all_task_ids[@]}"; do
            if [[ "$existing_id" == "$id" ]]; then
              err "ERROR: duplicate_task_id: task ID '$id' appears more than once"
              break
            fi
          done
        fi
      fi

      if [[ -n "$task_status" ]]; then
        case "$task_status" in
          pending|in_progress|complete|skipped) ;;
          *) err "ERROR: invalid_task_status: task $id status='$task_status' (expected: pending, in_progress, complete, or skipped)" ;;
        esac
      fi

      local files_exists
      files_exists=$(echo "$json" | jq ".phases[$p].tasks[$t] | has(\"files\")")
      if [[ "$files_exists" != "true" ]]; then
        err "ERROR: missing_field: phases[$p].tasks[$t].files"
      else
        local create_exists modify_exists test_exists
        create_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"create\")")
        modify_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"modify\")")
        test_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"test\")")

        [[ "$create_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.create"
        [[ "$modify_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.modify"
        [[ "$test_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.test"
      fi

      local depends_on_count
      depends_on_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].depends_on // []) | length")
      if [[ "$depends_on_count" -gt 0 ]]; then
        for ((d=0; d<depends_on_count; d++)); do
          local dep_id
          dep_id=$(echo "$json" | jq -r ".phases[$p].tasks[$t].depends_on[$d]")

          local found=0
          if [[ ${#all_task_ids[@]} -gt 0 ]]; then
            for existing_id in "${all_task_ids[@]}"; do
              if [[ "$existing_id" == "$dep_id" ]]; then
                found=1
                break
              fi
            done
          fi

          if [[ $found -eq 0 ]]; then
            err "ERROR: invalid_dependency: task $id depends_on $dep_id which doesn't exist in same or prior phase"
          fi
        done
      fi

      local create_count
      create_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].files.create // []) | length")
      for ((f=0; f<create_count; f++)); do
        local create_path
        create_path=$(echo "$json" | jq -r ".phases[$p].tasks[$t].files.create[$f]")

        if [[ ${#all_create_paths[@]} -gt 0 ]]; then
          for existing_path in "${all_create_paths[@]}"; do
            if [[ "$existing_path" == "$create_path" ]]; then
              err "ERROR: duplicate_create_path: $create_path appears in multiple tasks"
            fi
          done
        fi
        all_create_paths+=("$create_path")
      done

      local task_criteria_count
      task_criteria_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].success_criteria // []) | length")
      for ((c=0; c<task_criteria_count; c++)); do
        local run expect_exit expect_output
        run=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].run // empty")
        expect_exit=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].expect_exit // empty")
        expect_output=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].expect_output // empty")

        [[ -z "$run" ]] && err "ERROR: empty_run: task $id success_criteria[$c]"
        [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: task $id success_criteria[$c] has neither expect_exit nor expect_output"
      done

      local id_lower
      id_lower=$(echo "$id" | tr '[:upper:]' '[:lower:]')
      local task_file="$plan_dir/$phase_dir/$id_lower.md"
      if [[ ! -f "$task_file" ]]; then
        err "ERROR: missing_task_file: $phase_dir/$id_lower.md"
      else
        local first_line
        first_line=$(head -n 1 "$task_file")
        local expected_h1="# $id: $task_name"
        if [[ "$first_line" != "$expected_h1" ]]; then
          err "ERROR: h1_mismatch: $phase_dir/$id_lower.md first line is '$first_line', expected '$expected_h1'"
        fi
      fi

      all_task_ids+=("$id")
    done
  done

  if [ ${#ERRORS[@]} -gt 0 ]; then
    for e in "${ERRORS[@]}"; do echo "$e" >&2; done
    exit 1
  fi
  exit 0
}

do_render() {
  local plan_json="$1"
  local plan_dir
  plan_dir="$(dirname "$(realpath "$plan_json")")"
  local out="$plan_dir/plan.md"
  local tmp="${out}.tmp.$$"

  local plan_status goal architecture tech_stack
  plan_status=$(jq -r '.status' "$plan_json")
  goal=$(jq -r '.goal' "$plan_json")
  architecture=$(jq -r '.architecture' "$plan_json")
  tech_stack=$(jq -r '.tech_stack' "$plan_json")

  {
    printf -- '---\nstatus: %s\n---\n\n' "$plan_status"
    printf '# %s Implementation Plan\n\n' "$goal"
    printf '> **For Claude:** REQUIRED SUB-SKILL: Use orchestrate\n\n'
    printf '**Goal:** %s\n' "$goal"
    printf '**Architecture:** %s\n' "$architecture"
    printf '**Tech Stack:** %s\n' "$tech_stack"
    printf '\n---\n'

    local phase_count
    phase_count=$(jq '.phases | length' "$plan_json")

    for ((i=0; i<phase_count; i++)); do
      local letter name status rationale
      letter=$(jq -r ".phases[$i].letter" "$plan_json")
      name=$(jq -r ".phases[$i].name" "$plan_json")
      status=$(jq -r ".phases[$i].status" "$plan_json")
      rationale=$(jq -r ".phases[$i].rationale" "$plan_json")

      printf '\n## Phase %s — %s\n' "$letter" "$name"
      printf '**Status:** %s | **Rationale:** %s\n\n' "$status" "$rationale"

      local task_count
      task_count=$(jq ".phases[$i].tasks | length" "$plan_json")

      for ((j=0; j<task_count; j++)); do
        local tid tname tstatus done_when checkbox
        tid=$(jq -r ".phases[$i].tasks[$j].id" "$plan_json")
        tname=$(jq -r ".phases[$i].tasks[$j].name" "$plan_json")
        tstatus=$(jq -r ".phases[$i].tasks[$j].status" "$plan_json")
        done_when=$(jq -r ".phases[$i].tasks[$j].done_when" "$plan_json")

        if [ "$tstatus" = "complete" ]; then
          checkbox="[x]"
        elif [ "$tstatus" = "skipped" ]; then
          checkbox="[x]"
          tname="~~${tname}~~ (skipped)"
        else
          checkbox="[ ]"
        fi

        printf -- '- %s %s: %s — *%s*\n' "$checkbox" "$tid" "$tname" "$done_when"
      done
    done
  } > "$tmp"
  mv "$tmp" "$out"
}

do_update_status_task() {
  local plan_json="$1" task_id="$2" new_status="$3"
  local valid_statuses=("pending" "in_progress" "complete" "skipped")
  local valid=false
  for s in "${valid_statuses[@]}"; do
    if [ "$new_status" = "$s" ]; then valid=true; break; fi
  done
  if [ "$valid" = false ]; then
    echo "ERROR: invalid_task_status: '$new_status'" >&2
    exit 1
  fi
  local task_found
  task_found=$(jq --arg id "$task_id" '[.phases[].tasks[] | select(.id == $id)] | length' "$plan_json")
  if [ "$task_found" -eq 0 ]; then
    echo "ERROR: task_not_found: '$task_id' not found in plan" >&2
    exit 1
  fi
  local tmp="${plan_json}.tmp.$$"
  jq --arg id "$task_id" --arg status "$new_status" '
    (.phases[].tasks[] | select(.id == $id)).status = $status
  ' "$plan_json" > "$tmp" || { rm -f "$tmp"; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { echo "ERROR: failed to write plan.json" >&2; exit 1; }
  do_render "$plan_json"
}

do_update_status_phase() {
  local plan_json="$1" phase_letter="$2" new_status="$3"
  if [[ "$new_status" != "Not Started" && "$new_status" != "In Progress" && ! "$new_status" =~ ^Complete\ \(20[0-9]{2}-[0-1][0-9]-[0-3][0-9]\)$ ]]; then
    echo "ERROR: invalid_phase_status: '$new_status' (expected Not Started, In Progress, or Complete (YYYY-MM-DD))" >&2
    exit 1
  fi
  local phase_found
  phase_found=$(jq --arg letter "$phase_letter" '[.phases[] | select(.letter == $letter)] | length' "$plan_json")
  if [ "$phase_found" -eq 0 ]; then
    echo "ERROR: phase_not_found: '$phase_letter' not found in plan" >&2
    exit 1
  fi
  local tmp="${plan_json}.tmp.$$"
  jq --arg letter "$phase_letter" --arg status "$new_status" '
    (.phases[] | select(.letter == $letter)).status = $status
  ' "$plan_json" > "$tmp" || { rm -f "$tmp"; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { echo "ERROR: failed to write plan.json" >&2; exit 1; }
  do_render "$plan_json"
}

do_update_status_plan() {
  local plan_json="$1" new_status="$2"
  local valid_plan_statuses=("Not Yet Started" "In Development" "Complete")
  local valid=false
  for s in "${valid_plan_statuses[@]}"; do
    if [ "$new_status" = "$s" ]; then valid=true; break; fi
  done
  if [ "$valid" = false ]; then
    echo "ERROR: invalid_plan_status: '$new_status' (expected Not Yet Started, In Development, or Complete)" >&2
    exit 1
  fi
  local tmp="${plan_json}.tmp.$$"
  jq --arg status "$new_status" '.status = $status' "$plan_json" > "$tmp" || { rm -f "$tmp"; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { echo "ERROR: failed to write plan.json" >&2; exit 1; }
  do_render "$plan_json"
}

do_criteria() {
  local plan_json="$1" target="$2" target_id="${3:-}"

  local json
  json=$(cat "$plan_json")

  local criteria_json=""
  local scope_label=""

  case "$target" in
    task)
      if [[ -z "$target_id" ]]; then
        echo "ERROR: --criteria --task requires a task ID" >&2
        exit 2
      fi
      local task_found
      task_found=$(echo "$json" | jq --arg id "$target_id" '[.phases[].tasks[] | select(.id == $id)] | length')
      if [[ "$task_found" -eq 0 ]]; then
        echo "ERROR: task '$target_id' not found in plan" >&2
        exit 2
      fi
      criteria_json=$(echo "$json" | jq --arg id "$target_id" '[.phases[].tasks[] | select(.id == $id)][0].success_criteria // []')
      scope_label="task $target_id"
      ;;
    phase)
      if [[ -z "$target_id" ]]; then
        echo "ERROR: --criteria --phase requires a phase letter" >&2
        exit 2
      fi
      local phase_found
      phase_found=$(echo "$json" | jq --arg letter "$target_id" '[.phases[] | select(.letter == $letter)] | length')
      if [[ "$phase_found" -eq 0 ]]; then
        echo "ERROR: phase '$target_id' not found in plan" >&2
        exit 2
      fi
      criteria_json=$(echo "$json" | jq --arg letter "$target_id" '[.phases[] | select(.letter == $letter)][0].success_criteria // []')
      scope_label="phase $target_id"
      ;;
    plan)
      criteria_json=$(echo "$json" | jq '.success_criteria // []')
      scope_label="plan"
      ;;
    *)
      echo "ERROR: --criteria requires --task <ID>, --phase <LETTER>, or --plan" >&2
      exit 2
      ;;
  esac

  local count
  count=$(echo "$criteria_json" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    exit 0
  fi

  local timeout_cmd
  timeout_cmd=$(find_timeout_cmd)
  if [[ -z "$timeout_cmd" ]]; then
    echo "WARNING: neither timeout nor gtimeout found; commands will run without timeout enforcement" >&2
  fi

  local has_blocking_failure=0

  for ((i=0; i<count; i++)); do
    local run expect_exit expect_output severity timeout_secs
    run=$(echo "$criteria_json" | jq -r ".[$i].run")
    expect_exit=$(echo "$criteria_json" | jq -r ".[$i].expect_exit // empty")
    expect_output=$(echo "$criteria_json" | jq -r ".[$i].expect_output // empty")
    severity=$(echo "$criteria_json" | jq -r ".[$i].severity // \"blocking\"")
    timeout_secs=$(echo "$criteria_json" | jq -r ".[$i].timeout // 60")

    local stdout_file
    stdout_file=$(mktemp)

    local actual_exit=0
    if [[ -n "$timeout_cmd" ]]; then
      $timeout_cmd "$timeout_secs" bash -c "$run" > "$stdout_file" || actual_exit=$?
    else
      bash -c "$run" > "$stdout_file" || actual_exit=$?
    fi

    local exit_ok=true
    local output_ok=true
    local is_timeout=false

    if [[ "$actual_exit" -eq 124 && -n "$timeout_cmd" ]]; then
      is_timeout=true
    fi

    if [[ -n "$expect_exit" ]]; then
      if [[ "$actual_exit" -ne "$expect_exit" ]]; then
        exit_ok=false
      fi
    fi

    if [[ -n "$expect_output" ]]; then
      if ! grep -qF "$expect_output" "$stdout_file"; then
        output_ok=false
      fi
    fi

    local status_label details=""
    if [[ "$is_timeout" == "true" ]]; then
      status_label="TIMEOUT"
      details="killed after ${timeout_secs}s [blocking]"
      has_blocking_failure=1
    elif [[ "$exit_ok" == "true" && "$output_ok" == "true" ]]; then
      status_label="PASS"
      if [[ -n "$expect_exit" ]]; then
        details="exit=$actual_exit (expected $expect_exit)"
      fi
      if [[ -n "$expect_output" ]]; then
        [[ -n "$details" ]] && details="$details, "
        details="${details}output contains \"$expect_output\""
      fi
    else
      if [[ "$severity" == "warning" ]]; then
        status_label="WARN"
      else
        status_label="FAIL"
        has_blocking_failure=1
      fi
      if [[ -n "$expect_exit" && "$exit_ok" == "false" ]]; then
        details="exit=$actual_exit (expected $expect_exit)"
      fi
      if [[ -n "$expect_output" && "$output_ok" == "false" ]]; then
        [[ -n "$details" ]] && details="$details, "
        details="${details}output missing \"$expect_output\""
      fi
      if [[ "$severity" == "warning" ]]; then
        details="$details [warning, non-blocking]"
      fi
    fi

    echo "$status_label  $scope_label criteria[$i]: \"$run\" -- $details"
    rm -f "$stdout_file"
  done

  exit "$has_blocking_failure"
}

MODE=""
PLAN_JSON=""
UPDATE_TARGET=""
UPDATE_ID=""
UPDATE_STATUS=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --schema)
      MODE="schema"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --render)
      MODE="render"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --update-status)
      MODE="update-status"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --criteria)
      MODE="criteria"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --task)
      shift
      UPDATE_TARGET="task"
      if [[ $# -gt 0 ]]; then
        UPDATE_ID="$1"
        shift
      fi
      ;;
    --phase)
      shift
      UPDATE_TARGET="phase"
      if [[ $# -gt 0 ]]; then
        UPDATE_ID="$1"
        shift
      fi
      ;;
    --plan)
      UPDATE_TARGET="plan"
      shift
      ;;
    --status)
      shift
      if [[ $# -gt 0 ]]; then
        UPDATE_STATUS="$1"
        shift
      fi
      ;;
    *)
      usage
      ;;
  esac
done

[[ -z "$MODE" ]] && usage
[[ -z "$PLAN_JSON" ]] && usage

case "$MODE" in
  schema) do_schema "$PLAN_JSON" ;;
  render) do_render "$PLAN_JSON" ;;
  update-status)
    case "$UPDATE_TARGET" in
      task) do_update_status_task "$PLAN_JSON" "$UPDATE_ID" "$UPDATE_STATUS" ;;
      phase) do_update_status_phase "$PLAN_JSON" "$UPDATE_ID" "$UPDATE_STATUS" ;;
      plan) do_update_status_plan "$PLAN_JSON" "$UPDATE_STATUS" ;;
      *) usage ;;
    esac
    ;;
  criteria)
    case "$UPDATE_TARGET" in
      task) do_criteria "$PLAN_JSON" "task" "$UPDATE_ID" ;;
      phase) do_criteria "$PLAN_JSON" "phase" "$UPDATE_ID" ;;
      plan) do_criteria "$PLAN_JSON" "plan" ;;
      *) echo "ERROR: --criteria requires --task <ID>, --phase <LETTER>, or --plan" >&2; exit 2 ;;
    esac
    ;;
  *) usage ;;
esac
