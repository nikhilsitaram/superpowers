#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  validate-plan --schema <plan.json>
  validate-plan --render <plan.json>
  validate-plan --update-status <plan.json> --task <ID> --status <STATUS>
  validate-plan --update-status <plan.json> --phase <LETTER> --status <STATUS>
  validate-plan --update-status <plan.json> --plan --status <STATUS>
  validate-plan --criteria <plan.json> --task <ID>
  validate-plan --criteria <plan.json> --phase <LETTER>
  validate-plan --criteria <plan.json> --plan
  validate-plan --check-review <plan.json> --type <TYPE> --scope <SCOPE>
  validate-plan --consistency <plan.json>
  validate-plan --check-entry <plan.json> --stage <STAGE>
  validate-plan --check-base <plan.json>
  validate-plan --check-deps <plan.json> --task <ID>
  validate-plan --check-workflow <plan.json>

  Valid types:  design-review, plan-review, task-review, impl-review
  Valid scopes: design, plan, task-{ID}, phase-{letter}, final
  Valid stages: draft-plan, execution
USAGE
  exit 1
}

ERRORS=()
err() { ERRORS+=("$1"); }

lock_plan() {
  local plan_json="$1"
  local lock_dir="${plan_json}.lock"
  local retries=0
  while ! mkdir "$lock_dir" 2>/dev/null; do
    retries=$((retries + 1))
    if [[ $retries -gt 50 ]]; then
      echo "ERROR: could not acquire lock on $plan_json after 5 seconds" >&2
      exit 1
    fi
    sleep 0.1
  done
}

unlock_plan() {
  local plan_json="$1"
  rmdir "${plan_json}.lock" 2>/dev/null || true
}

find_timeout_cmd() {
  if command -v timeout >/dev/null 2>&1; then
    echo "timeout"
  elif command -v gtimeout >/dev/null 2>&1; then
    echo "gtimeout"
  else
    echo ""
  fi
}

do_schema() {
  local plan_json="$1"
  local plan_dir
  plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"

  local json
  json=$(cat "$plan_json")

  local schema status goal architecture tech_stack
  schema=$(echo "$json" | jq -r '.schema // empty')
  status=$(echo "$json" | jq -r '.status // empty')
  goal=$(echo "$json" | jq -r '.goal // empty')
  architecture=$(echo "$json" | jq -r '.architecture // empty')
  tech_stack=$(echo "$json" | jq -r '.tech_stack // empty')

  [[ -z "$schema" ]] && err "ERROR: missing_field: schema"
  [[ -z "$status" ]] && err "ERROR: missing_field: status"
  [[ -z "$goal" ]] && err "ERROR: missing_field: goal"
  [[ -z "$architecture" ]] && err "ERROR: missing_field: architecture"
  [[ -z "$tech_stack" ]] && err "ERROR: missing_field: tech_stack"

  local workflow
  workflow=$(echo "$json" | jq -r '.workflow // empty')
  if [[ -z "$workflow" ]]; then
    err "ERROR: missing_field: workflow"
  else
    case "$workflow" in
      "pr-create"|"pr-merge"|"plan-only") ;;
      *) err "ERROR: invalid_workflow: $workflow" ;;
    esac
  fi

  local execution_mode
  execution_mode=$(echo "$json" | jq -r '.execution_mode // empty')
  if [[ -z "$execution_mode" ]]; then
    err "ERROR: missing_field: execution_mode"
  else
    case "$execution_mode" in
      "subagents"|"agent-teams") ;;
      *) err "ERROR: invalid_execution_mode: $execution_mode (expected: subagents or agent-teams)" ;;
    esac
  fi

  local integration_branch
  integration_branch=$(echo "$json" | jq -r '.integration_branch // empty')
  if [[ -n "$integration_branch" ]]; then
    if [[ "$integration_branch" =~ ^[[:space:]]*$ ]]; then
      err "ERROR: invalid_integration_branch: integration_branch must be a non-empty string"
    fi
  fi

  if [[ -n "$status" ]]; then
    case "$status" in
      "Not Yet Started"|"In Development"|"Complete") ;;
      *) err "ERROR: invalid_plan_status: '$status' (expected: Not Yet Started, In Development, or Complete)" ;;
    esac
  fi

  local plan_criteria_count
  plan_criteria_count=$(echo "$json" | jq '(.success_criteria // []) | length')
  for ((i=0; i<plan_criteria_count; i++)); do
    local run expect_exit expect_output
    run=$(echo "$json" | jq -r ".success_criteria[$i].run // empty")
    expect_exit=$(echo "$json" | jq -r ".success_criteria[$i].expect_exit // empty")
    expect_output=$(echo "$json" | jq -r ".success_criteria[$i].expect_output // empty")

    [[ -z "$run" ]] && err "ERROR: empty_run: plan success_criteria[$i]"
    [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: plan success_criteria[$i] has neither expect_exit nor expect_output"
  done

  local phase_count
  phase_count=$(echo "$json" | jq '(.phases // []) | length')
  [[ "$phase_count" -eq 0 ]] && err "ERROR: empty_phases: plan must have at least one phase"

  local all_task_ids=()
  local all_create_paths=()
  local seen_phase_letters=""
  local prev_phase_letter=""

  for ((p=0; p<phase_count; p++)); do
    local letter name phase_status rationale
    letter=$(echo "$json" | jq -r ".phases[$p].letter // empty")
    name=$(echo "$json" | jq -r ".phases[$p].name // empty")
    phase_status=$(echo "$json" | jq -r ".phases[$p].status // empty")
    rationale=$(echo "$json" | jq -r ".phases[$p].rationale // empty")

    [[ -z "$letter" ]] && err "ERROR: missing_field: phases[$p].letter"
    [[ -z "$name" ]] && err "ERROR: missing_field: phases[$p].name"
    [[ -z "$phase_status" ]] && err "ERROR: missing_field: phases[$p].status"
    [[ -z "$rationale" ]] && err "ERROR: missing_field: phases[$p].rationale"

    if [[ -n "$letter" ]]; then
      if [[ ! "$letter" =~ ^[A-Z]$ ]]; then
        err "ERROR: invalid_phase_letter_format: phases[$p].letter='$letter' must be a single uppercase A-Z character"
      fi
      if [[ " $seen_phase_letters " == *" $letter "* ]]; then
        err "ERROR: duplicate_phase_letter: phase letter '$letter' appears more than once"
      fi

      local phase_has_deps
      phase_has_deps=$(echo "$json" | jq ".phases[$p] | has(\"depends_on\")")
      if [[ "$phase_has_deps" != "true" ]]; then
        err "ERROR: missing_field: phases[$p].depends_on"
      else
        local phase_dep_count
        phase_dep_count=$(echo "$json" | jq "(.phases[$p].depends_on // []) | length")
        for ((pd=0; pd<phase_dep_count; pd++)); do
          local phase_dep_ref
          phase_dep_ref=$(echo "$json" | jq -r ".phases[$p].depends_on[$pd]")
          if [[ " $seen_phase_letters " != *" $phase_dep_ref "* ]]; then
            err "ERROR: invalid_depends_on: Phase $letter references $phase_dep_ref which is not an earlier phase"
          fi
        done
      fi

      if [[ -n "$prev_phase_letter" ]]; then
        if [[ "$letter" < "$prev_phase_letter" || "$letter" == "$prev_phase_letter" ]]; then
          err "ERROR: phase_order: phase $letter must come after $prev_phase_letter (alphabetical order required)"
        fi
      fi
      prev_phase_letter="$letter"

      seen_phase_letters="$seen_phase_letters $letter"
    fi

    if [[ -n "$phase_status" ]]; then
      case "$phase_status" in
        "Not Started"|"In Progress") ;;
        Complete\ \(20[0-9][0-9]-[0-1][0-9]-[0-3][0-9]\)) ;;
        *) err "ERROR: invalid_phase_status: phases[$p].status='$phase_status' (expected: Not Started, In Progress, or Complete (YYYY-MM-DD))" ;;
      esac
    fi

    local phase_criteria_count
    phase_criteria_count=$(echo "$json" | jq "(.phases[$p].success_criteria // []) | length")
    for ((c=0; c<phase_criteria_count; c++)); do
      local run expect_exit expect_output
      run=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].run // empty")
      expect_exit=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].expect_exit // empty")
      expect_output=$(echo "$json" | jq -r ".phases[$p].success_criteria[$c].expect_output // empty")

      [[ -z "$run" ]] && err "ERROR: empty_run: phase $letter success_criteria[$c]"
      [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: phase $letter success_criteria[$c] has neither expect_exit nor expect_output"
    done

    local letter_lower
    letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')
    local phase_dir="phase-$letter_lower"
    if [[ ! -f "$plan_dir/$phase_dir/completion.md" ]]; then
      err "ERROR: missing_completion_file: $phase_dir/completion.md"
    fi

    local task_count
    task_count=$(echo "$json" | jq "(.phases[$p].tasks // []) | length")

    for ((t=0; t<task_count; t++)); do
      local id task_name task_status verification done_when
      id=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id // empty")
      task_name=$(echo "$json" | jq -r ".phases[$p].tasks[$t].name // empty")
      task_status=$(echo "$json" | jq -r ".phases[$p].tasks[$t].status // empty")
      verification=$(echo "$json" | jq -r ".phases[$p].tasks[$t].verification // empty")
      done_when=$(echo "$json" | jq -r ".phases[$p].tasks[$t].done_when // empty")

      [[ -z "$id" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].id"
      [[ -z "$task_name" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].name"
      [[ -z "$task_status" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].status"
      [[ -z "$verification" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].verification"
      [[ -z "$done_when" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].done_when"

      if [[ -n "$id" ]]; then
        if [[ ${#all_task_ids[@]} -gt 0 ]]; then
          for existing_id in "${all_task_ids[@]}"; do
            if [[ "$existing_id" == "$id" ]]; then
              err "ERROR: duplicate_task_id: task ID '$id' appears more than once"
              break
            fi
          done
        fi
        if [[ -n "$letter" ]]; then
          local id_prefix="${id:0:1}"
          if [[ "$id_prefix" != "$letter" ]]; then
            err "ERROR: task_id_phase_mismatch: task $id has prefix '$id_prefix' but belongs to phase $letter"
          fi
        fi
      fi

      if [[ -n "$task_status" ]]; then
        case "$task_status" in
          pending|in_progress|complete|skipped) ;;
          *) err "ERROR: invalid_task_status: task $id status='$task_status' (expected: pending, in_progress, complete, or skipped)" ;;
        esac
      fi

      local files_exists
      files_exists=$(echo "$json" | jq ".phases[$p].tasks[$t] | has(\"files\")")
      if [[ "$files_exists" != "true" ]]; then
        err "ERROR: missing_field: phases[$p].tasks[$t].files"
      else
        local create_exists modify_exists test_exists
        create_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"create\")")
        modify_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"modify\")")
        test_exists=$(echo "$json" | jq ".phases[$p].tasks[$t].files | has(\"test\")")

        [[ "$create_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.create"
        [[ "$modify_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.modify"
        [[ "$test_exists" != "true" ]] && err "ERROR: missing_field: phases[$p].tasks[$t].files.test"
      fi

      local depends_on_count
      depends_on_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].depends_on // []) | length")
      if [[ "$depends_on_count" -gt 0 ]]; then
        for ((d=0; d<depends_on_count; d++)); do
          local dep_id
          dep_id=$(echo "$json" | jq -r ".phases[$p].tasks[$t].depends_on[$d]")

          local found=0
          if [[ ${#all_task_ids[@]} -gt 0 ]]; then
            for existing_id in "${all_task_ids[@]}"; do
              if [[ "$existing_id" == "$dep_id" ]]; then
                found=1
                break
              fi
            done
          fi

          if [[ $found -eq 0 ]]; then
            err "ERROR: invalid_dependency: task $id depends_on $dep_id which doesn't exist in same or prior phase"
          fi
        done
      fi

      local create_count
      create_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].files.create // []) | length")
      for ((f=0; f<create_count; f++)); do
        local create_path
        create_path=$(echo "$json" | jq -r ".phases[$p].tasks[$t].files.create[$f]")

        if [[ ${#all_create_paths[@]} -gt 0 ]]; then
          for existing_path in "${all_create_paths[@]}"; do
            if [[ "$existing_path" == "$create_path" ]]; then
              err "ERROR: duplicate_create_path: $create_path appears in multiple tasks"
            fi
          done
        fi
        all_create_paths+=("$create_path")
      done

      local task_criteria_count
      task_criteria_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].success_criteria // []) | length")
      for ((c=0; c<task_criteria_count; c++)); do
        local run expect_exit expect_output
        run=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].run // empty")
        expect_exit=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].expect_exit // empty")
        expect_output=$(echo "$json" | jq -r ".phases[$p].tasks[$t].success_criteria[$c].expect_output // empty")

        [[ -z "$run" ]] && err "ERROR: empty_run: task $id success_criteria[$c]"
        [[ -z "$expect_exit" && -z "$expect_output" ]] && err "ERROR: missing_expect: task $id success_criteria[$c] has neither expect_exit nor expect_output"
      done

      local id_lower
      id_lower=$(echo "$id" | tr '[:upper:]' '[:lower:]')
      local task_file="$plan_dir/$phase_dir/$id_lower.md"
      if [[ ! -f "$task_file" ]]; then
        err "ERROR: missing_task_file: $phase_dir/$id_lower.md"
      else
        local first_line
        first_line=$(head -n 1 "$task_file")
        local expected_h1="# $id: $task_name"
        if [[ "$first_line" != "$expected_h1" ]]; then
          err "ERROR: h1_mismatch: $phase_dir/$id_lower.md first line is '$first_line', expected '$expected_h1'"
        fi
      fi

      if [[ "$task_status" == "complete" ]]; then
        local completion_file="$plan_dir/$phase_dir/${id_lower}-completion.md"
        if [[ ! -f "$completion_file" ]]; then
          err "ERROR: missing_task_completion_file: $phase_dir/${id_lower}-completion.md"
        fi

        local repo_root
        repo_root=$(git -C "$plan_dir" rev-parse --show-toplevel 2>/dev/null || echo "")
        if [[ -n "$repo_root" ]]; then
          local fc_count
          fc_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].files.create // []) | length")
          for ((fc=0; fc<fc_count; fc++)); do
            local fc_path
            fc_path=$(echo "$json" | jq -r ".phases[$p].tasks[$t].files.create[$fc]")
            if [[ ! -f "$repo_root/$fc_path" ]]; then
              err "ERROR: missing_created_file: task $id declares files.create '$fc_path' but file not found"
            fi
          done
        fi
      fi

      all_task_ids+=("$id")
    done

    local phase_file_paths=()
    local phase_file_tids=()
    for ((t=0; t<task_count; t++)); do
      local tid
      tid=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id // empty")
      for arr in create modify test; do
        local arr_count
        arr_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].files.${arr} // []) | length")
        for ((f=0; f<arr_count; f++)); do
          local fpath
          fpath=$(echo "$json" | jq -r ".phases[$p].tasks[$t].files.${arr}[$f]")
          local existing_owner=""
          for ((i=0; i<${#phase_file_paths[@]}; i++)); do
            if [[ "${phase_file_paths[$i]}" == "$fpath" ]]; then
              existing_owner="${phase_file_tids[$i]}"
              break
            fi
          done
          if [[ -n "$existing_owner" && "$existing_owner" != "$tid" ]]; then
            err "ERROR: fileset_overlap: file '$fpath' claimed by tasks $existing_owner and $tid in phase $letter"
          elif [[ -z "$existing_owner" ]]; then
            phase_file_paths+=("$fpath")
            phase_file_tids+=("$tid")
          fi
        done
      done
    done

    local phase_full_dir="$plan_dir/$phase_dir"
    if [[ -d "$phase_full_dir" ]]; then
      for md_file in "$phase_full_dir"/*.md; do
        [[ ! -f "$md_file" ]] && continue
        local base_name
        base_name=$(basename "$md_file" .md)
        [[ "$base_name" == "completion" ]] && continue
        [[ "$base_name" =~ -completion$ ]] && continue
        local found_task=0
        for ((t=0; t<task_count; t++)); do
          local tid_lower
          tid_lower=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id // empty" | tr '[:upper:]' '[:lower:]')
          if [[ "$base_name" == "$tid_lower" ]]; then
            found_task=1
            break
          fi
        done
        if [[ $found_task -eq 0 ]]; then
          err "ERROR: orphaned_task_file: $phase_dir/$base_name.md has no matching task in plan.json"
        fi
      done
    fi

  done

  # Defense-in-depth: BFS cycle check across phase depends_on edges.
  # The backward-reference check above already guarantees acyclicity:
  # every depends_on entry must reference a phase that appeared earlier
  # in the phases array, so forward references — and therefore cycles —
  # are impossible by construction. This BFS block will never fire
  # independently of that check; it is kept as a safety net in case the
  # ordering constraint is relaxed in the future.
  local cd_cycle_detected=0
  for ((cd_start=0; cd_start<phase_count && cd_cycle_detected==0; cd_start++)); do
    local cd_start_letter
    cd_start_letter=$(echo "$json" | jq -r ".phases[$cd_start].letter")
    local cd_visited=""
    local -a cd_queue=("$cd_start_letter")
    while [[ ${#cd_queue[@]} -gt 0 && $cd_cycle_detected -eq 0 ]]; do
      local cd_current="${cd_queue[0]}"
      cd_queue=("${cd_queue[@]:1}")
      if [[ " $cd_visited " == *" $cd_current "* ]]; then
        continue
      fi
      cd_visited="$cd_visited $cd_current"
      local cd_dep_cnt
      cd_dep_cnt=$(echo "$json" | jq --arg l "$cd_current" '([.phases[] | select(.letter == $l)][0].depends_on // []) | length')
      for ((cd_d=0; cd_d<cd_dep_cnt; cd_d++)); do
        local cd_dep
        cd_dep=$(echo "$json" | jq -r --arg l "$cd_current" --argjson idx "$cd_d" '([.phases[] | select(.letter == $l)][0].depends_on // [])[$idx]')
        if [[ "$cd_dep" == "$cd_start_letter" && "$cd_current" != "$cd_start_letter" ]]; then
          err "ERROR: circular_dependency: cycle detected involving phase $cd_start_letter"
          cd_cycle_detected=1
          break
        fi
        if [[ " $cd_visited " != *" $cd_dep "* ]]; then
          cd_queue+=("$cd_dep")
        fi
      done
    done
  done

  if [ ${#ERRORS[@]} -gt 0 ]; then
    for e in "${ERRORS[@]}"; do echo "$e" >&2; done
    exit 1
  fi

  # Chain to consistency checks so --schema callers don't lose coverage
  if ! do_consistency "$plan_json"; then
    exit 1
  fi
  exit 0
}

do_consistency() {
  local plan_json="$1"
  local json
  json=$(cat "$plan_json")

  local plan_status
  plan_status=$(echo "$json" | jq -r '.status // empty')

  local phase_count
  phase_count=$(echo "$json" | jq '(.phases // []) | length')

  ERRORS=()

  for ((p=0; p<phase_count; p++)); do
    local letter phase_status
    letter=$(echo "$json" | jq -r ".phases[$p].letter // empty")
    phase_status=$(echo "$json" | jq -r ".phases[$p].status // empty")
    local task_count
    task_count=$(echo "$json" | jq "(.phases[$p].tasks // []) | length")

    if [[ "$phase_status" == "Not Started" ]]; then
      for ((t=0; t<task_count; t++)); do
        local ts
        ts=$(echo "$json" | jq -r ".phases[$p].tasks[$t].status // empty")
        if [[ "$ts" == "in_progress" || "$ts" == "complete" ]]; then
          err "ERROR: status_inconsistency: phase $letter is 'Not Started' but task $(echo "$json" | jq -r ".phases[$p].tasks[$t].id") is '$ts'"
        fi
      done
    fi

    if [[ "$phase_status" =~ ^Complete ]]; then
      for ((t=0; t<task_count; t++)); do
        local ts
        ts=$(echo "$json" | jq -r ".phases[$p].tasks[$t].status // empty")
        if [[ "$ts" != "complete" && "$ts" != "skipped" ]]; then
          err "ERROR: status_inconsistency: phase $letter is '$phase_status' but task $(echo "$json" | jq -r ".phases[$p].tasks[$t].id") is '$ts'"
        fi
      done
    fi

    for ((t=0; t<task_count; t++)); do
      local ts tid
      ts=$(echo "$json" | jq -r ".phases[$p].tasks[$t].status // empty")
      tid=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id // empty")
      if [[ "$ts" == "complete" ]]; then
        local dep_count
        dep_count=$(echo "$json" | jq "(.phases[$p].tasks[$t].depends_on // []) | length")
        for ((d=0; d<dep_count; d++)); do
          local dep_id
          dep_id=$(echo "$json" | jq -r ".phases[$p].tasks[$t].depends_on[$d]")
          local dep_status=""
          for ((p2=0; p2<phase_count; p2++)); do
            local tc2
            tc2=$(echo "$json" | jq "(.phases[$p2].tasks // []) | length")
            for ((t2=0; t2<tc2; t2++)); do
              local tid2
              tid2=$(echo "$json" | jq -r ".phases[$p2].tasks[$t2].id")
              if [[ "$tid2" == "$dep_id" ]]; then
                dep_status=$(echo "$json" | jq -r ".phases[$p2].tasks[$t2].status")
                break 2
              fi
            done
          done
          if [[ "$dep_status" == "pending" || "$dep_status" == "in_progress" ]]; then
            err "ERROR: status_inconsistency: task $tid is 'complete' but dependency $dep_id is '$dep_status'"
          fi
        done
      fi
    done

    if [[ "$phase_status" =~ ^Complete ]]; then
      local letter_lower
      letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')
      local plan_dir
      plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"
      if ! check_review_record "$plan_dir" "impl-review" "phase-$letter_lower" > /dev/null 2>&1; then
        err "ERROR: status_inconsistency: phase $letter is '$phase_status' but no passing impl-review record for scope phase-$letter_lower"
      fi
    fi
  done

  if [[ "$plan_status" == "Not Yet Started" ]]; then
    for ((p=0; p<phase_count; p++)); do
      local ps
      ps=$(echo "$json" | jq -r ".phases[$p].status // empty")
      if [[ "$ps" == "In Progress" || "$ps" =~ ^Complete ]]; then
        err "ERROR: status_inconsistency: plan is 'Not Yet Started' but phase $(echo "$json" | jq -r ".phases[$p].letter") is '$ps'"
      fi
    done
  fi

  if [[ "$plan_status" == "Complete" ]]; then
    for ((p=0; p<phase_count; p++)); do
      local ps
      ps=$(echo "$json" | jq -r ".phases[$p].status // empty")
      if [[ ! "$ps" =~ ^Complete ]]; then
        err "ERROR: status_inconsistency: plan is Complete but phase $(echo "$json" | jq -r ".phases[$p].letter") is '$ps'"
      fi
    done
  fi

  if [ ${#ERRORS[@]} -gt 0 ]; then
    for e in "${ERRORS[@]}"; do echo "$e" >&2; done
    return 1
  fi
  return 0
}

do_check_entry() {
  local plan_json="$1" stage="$2"
  local plan_dir
  plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"

  case "$stage" in
    draft-plan)
      local result
      if ! result=$(check_review_record "$plan_dir" "design-review" "design"); then
        echo "ERROR: entry gate failed for stage '$stage' — design-review not passed ($result). Run design-review first." >&2
        exit 1
      fi
      ;;
    execution)
      local gate_errors=()
      local result
      if ! result=$(check_review_record "$plan_dir" "design-review" "design"); then
        gate_errors+=("design-review: $result")
      fi
      if ! result=$(check_review_record "$plan_dir" "plan-review" "plan"); then
        gate_errors+=("plan-review: $result")
      fi
      if [[ ${#gate_errors[@]} -gt 0 ]]; then
        echo "ERROR: entry gate failed for stage '$stage':" >&2
        for ge in "${gate_errors[@]}"; do echo "  - $ge" >&2; done
        echo "Run the missing reviews before starting execution." >&2
        exit 1
      fi
      ;;
    *)
      echo "ERROR: unknown stage '$stage' (expected: draft-plan or execution)" >&2
      exit 2
      ;;
  esac
  exit 0
}

do_check_base() {
  local plan_json="$1"
  local json
  json=$(cat "$plan_json")

  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  if [[ -z "$current_branch" ]]; then
    echo "ERROR: not in a git repository" >&2
    exit 1
  fi

  local integration_branch
  integration_branch=$(echo "$json" | jq -r '.integration_branch // empty')

  if [[ -n "$integration_branch" ]]; then
    if [[ "$current_branch" != "$integration_branch" ]]; then
      echo "ERROR: base_branch_mismatch: current branch '$current_branch' does not match integration_branch '$integration_branch'. Run from the integration worktree." >&2
      exit 1
    fi
  else
    if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
      echo "ERROR: base_branch_mismatch: current branch is '$current_branch'. Run from a feature worktree, not the main checkout." >&2
      exit 1
    fi
  fi
  exit 0
}

do_render() {
  local plan_json="$1"
  local plan_dir
  plan_dir="$(dirname "$(realpath "$plan_json")")"
  local out="$plan_dir/plan.md"
  local tmp="${out}.tmp.$$"

  local plan_status goal architecture tech_stack
  plan_status=$(jq -r '.status' "$plan_json")
  goal=$(jq -r '.goal' "$plan_json")
  architecture=$(jq -r '.architecture' "$plan_json")
  tech_stack=$(jq -r '.tech_stack' "$plan_json")

  {
    printf -- '---\nstatus: %s\n---\n\n' "$plan_status"
    printf '# %s Implementation Plan\n\n' "$goal"
    printf '> **For Claude:** REQUIRED SUB-SKILL: Use orchestrate\n\n'
    printf '**Goal:** %s\n' "$goal"
    printf '**Architecture:** %s\n' "$architecture"
    printf '**Tech Stack:** %s\n' "$tech_stack"
    printf '\n---\n'

    local phase_count
    phase_count=$(jq '.phases | length' "$plan_json")

    for ((i=0; i<phase_count; i++)); do
      local letter name status rationale
      letter=$(jq -r ".phases[$i].letter" "$plan_json")
      name=$(jq -r ".phases[$i].name" "$plan_json")
      status=$(jq -r ".phases[$i].status" "$plan_json")
      rationale=$(jq -r ".phases[$i].rationale" "$plan_json")

      printf '\n## Phase %s — %s\n' "$letter" "$name"
      printf '**Status:** %s | **Rationale:** %s\n\n' "$status" "$rationale"

      local task_count
      task_count=$(jq ".phases[$i].tasks | length" "$plan_json")

      for ((j=0; j<task_count; j++)); do
        local tid tname tstatus done_when checkbox
        tid=$(jq -r ".phases[$i].tasks[$j].id" "$plan_json")
        tname=$(jq -r ".phases[$i].tasks[$j].name" "$plan_json")
        tstatus=$(jq -r ".phases[$i].tasks[$j].status" "$plan_json")
        done_when=$(jq -r ".phases[$i].tasks[$j].done_when" "$plan_json")

        if [ "$tstatus" = "complete" ]; then
          checkbox="[x]"
        elif [ "$tstatus" = "skipped" ]; then
          checkbox="[x]"
          tname="~~${tname}~~ (skipped)"
        else
          checkbox="[ ]"
        fi

        printf -- '- %s %s: %s — *%s*\n' "$checkbox" "$tid" "$tname" "$done_when"
      done
    done
  } > "$tmp"
  mv "$tmp" "$out"
}

do_update_status_task() {
  local plan_json="$1" task_id="$2" new_status="$3"
  local valid_statuses=("pending" "in_progress" "complete" "skipped")
  local valid=false
  for s in "${valid_statuses[@]}"; do
    if [ "$new_status" = "$s" ]; then valid=true; break; fi
  done
  if [ "$valid" = false ]; then
    echo "ERROR: invalid_task_status: '$new_status'" >&2
    exit 1
  fi
  lock_plan "$plan_json"
  trap 'unlock_plan "'"$plan_json"'"' EXIT
  local task_found
  task_found=$(jq --arg id "$task_id" '[.phases[].tasks[] | select(.id == $id)] | length' "$plan_json")
  if [ "$task_found" -eq 0 ]; then
    unlock_plan "$plan_json"
    trap - EXIT
    echo "ERROR: task_not_found: '$task_id' not found in plan" >&2
    exit 1
  fi
  local tmp="${plan_json}.tmp.$$"
  jq --arg id "$task_id" --arg status "$new_status" '
    (.phases[].tasks[] | select(.id == $id)).status = $status
  ' "$plan_json" > "$tmp" || { rm -f "$tmp"; unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: failed to write plan.json" >&2; exit 1; }
  unlock_plan "$plan_json"
  trap - EXIT
  do_render "$plan_json"
}

do_update_status_phase() {
  local plan_json="$1" phase_letter="$2" new_status="$3"
  if [[ "$new_status" != "Not Started" && "$new_status" != "In Progress" && ! "$new_status" =~ ^Complete\ \(20[0-9]{2}-[0-1][0-9]-[0-3][0-9]\)$ ]]; then
    echo "ERROR: invalid_phase_status: '$new_status' (expected Not Started, In Progress, or Complete (YYYY-MM-DD))" >&2
    exit 1
  fi
  lock_plan "$plan_json"
  trap 'unlock_plan "'"$plan_json"'"' EXIT
  local phase_found
  phase_found=$(jq --arg letter "$phase_letter" '[.phases[] | select(.letter == $letter)] | length' "$plan_json")
  if [ "$phase_found" -eq 0 ]; then
    unlock_plan "$plan_json"
    trap - EXIT
    echo "ERROR: phase_not_found: '$phase_letter' not found in plan" >&2
    exit 1
  fi
  if [[ "$new_status" =~ ^Complete ]]; then
    local plan_dir
    plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"
    local phase_lower
    phase_lower=$(echo "$phase_letter" | tr '[:upper:]' '[:lower:]')
    local gate_result
    if ! gate_result=$(check_review_record "$plan_dir" "impl-review" "phase-$phase_lower"); then
      unlock_plan "$plan_json"
      trap - EXIT
      echo "ERROR: cannot mark phase $phase_letter complete — $gate_result" >&2
      exit 1
    fi
  fi
  local tmp="${plan_json}.tmp.$$"
  jq --arg letter "$phase_letter" --arg status "$new_status" '
    (.phases[] | select(.letter == $letter)).status = $status
  ' "$plan_json" > "$tmp" || { rm -f "$tmp"; unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: failed to write plan.json" >&2; exit 1; }
  unlock_plan "$plan_json"
  trap - EXIT
  do_render "$plan_json"
}

do_update_status_plan() {
  local plan_json="$1" new_status="$2"
  local valid_plan_statuses=("Not Yet Started" "In Development" "Complete")
  local valid=false
  for s in "${valid_plan_statuses[@]}"; do
    if [ "$new_status" = "$s" ]; then valid=true; break; fi
  done
  if [ "$valid" = false ]; then
    echo "ERROR: invalid_plan_status: '$new_status' (expected Not Yet Started, In Development, or Complete)" >&2
    exit 1
  fi
  if [[ "$new_status" == "Complete" ]]; then
    local plan_dir
    plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"
    local gate_errors=()
    local gate_result

    if ! gate_result=$(check_review_record "$plan_dir" "design-review" "design"); then
      gate_errors+=("design-review: $gate_result")
    fi

    if ! gate_result=$(check_review_record "$plan_dir" "plan-review" "plan"); then
      gate_errors+=("plan-review: $gate_result")
    fi

    local json
    json=$(cat "$plan_json")
    local phase_count
    phase_count=$(echo "$json" | jq '.phases | length')

    local incomplete_phases
    incomplete_phases=$(echo "$json" | jq -r '[.phases[] | select((.status | startswith("Complete")) | not) | .letter] | join(", ")')
    if [[ -n "$incomplete_phases" ]]; then
      gate_errors+=("phases not complete: $incomplete_phases")
    fi

    for ((p=0; p<phase_count; p++)); do
      local letter letter_lower
      letter=$(echo "$json" | jq -r ".phases[$p].letter")
      letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')

      if ! gate_result=$(check_review_record "$plan_dir" "impl-review" "phase-$letter_lower"); then
        gate_errors+=("impl-review phase-$letter_lower: $gate_result")
      fi
    done

    if [[ "$phase_count" -gt 1 ]]; then
      if ! gate_result=$(check_review_record "$plan_dir" "impl-review" "final"); then
        gate_errors+=("impl-review final: $gate_result")
      fi
    fi

    if [[ ${#gate_errors[@]} -gt 0 ]]; then
      echo "ERROR: cannot mark plan complete — missing review gates:" >&2
      for ge in "${gate_errors[@]}"; do
        echo "  - $ge" >&2
      done
      exit 1
    fi
  fi
  lock_plan "$plan_json"
  trap 'unlock_plan "'"$plan_json"'"' EXIT
  local tmp="${plan_json}.tmp.$$"
  jq --arg status "$new_status" '.status = $status' "$plan_json" > "$tmp" || { rm -f "$tmp"; unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: jq update failed" >&2; exit 1; }
  mv "$tmp" "$plan_json" || { unlock_plan "$plan_json"; trap - EXIT; echo "ERROR: failed to write plan.json" >&2; exit 1; }
  unlock_plan "$plan_json"
  trap - EXIT
  do_render "$plan_json"
}

do_criteria() {
  local plan_json="$1" target="$2" target_id="${3:-}"

  local json
  json=$(cat "$plan_json")

  local criteria_json=""
  local scope_label=""

  case "$target" in
    task)
      if [[ -z "$target_id" ]]; then
        echo "ERROR: --criteria --task requires a task ID" >&2
        exit 2
      fi
      local task_found
      task_found=$(echo "$json" | jq --arg id "$target_id" '[.phases[].tasks[] | select(.id == $id)] | length')
      if [[ "$task_found" -eq 0 ]]; then
        echo "ERROR: task '$target_id' not found in plan" >&2
        exit 2
      fi
      criteria_json=$(echo "$json" | jq --arg id "$target_id" '[.phases[].tasks[] | select(.id == $id)][0].success_criteria // []')
      scope_label="task $target_id"
      ;;
    phase)
      if [[ -z "$target_id" ]]; then
        echo "ERROR: --criteria --phase requires a phase letter" >&2
        exit 2
      fi
      local phase_found
      phase_found=$(echo "$json" | jq --arg letter "$target_id" '[.phases[] | select(.letter == $letter)] | length')
      if [[ "$phase_found" -eq 0 ]]; then
        echo "ERROR: phase '$target_id' not found in plan" >&2
        exit 2
      fi
      criteria_json=$(echo "$json" | jq --arg letter "$target_id" '[.phases[] | select(.letter == $letter)][0].success_criteria // []')
      scope_label="phase $target_id"
      ;;
    plan)
      criteria_json=$(echo "$json" | jq '.success_criteria // []')
      scope_label="plan"
      ;;
    *)
      echo "ERROR: --criteria requires --task <ID>, --phase <LETTER>, or --plan" >&2
      exit 2
      ;;
  esac

  local count
  count=$(echo "$criteria_json" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    exit 0
  fi

  local timeout_cmd
  timeout_cmd=$(find_timeout_cmd)
  if [[ -z "$timeout_cmd" ]]; then
    echo "WARNING: neither timeout nor gtimeout found; commands will run without timeout enforcement" >&2
  fi

  local has_blocking_failure=0

  for ((i=0; i<count; i++)); do
    local run expect_exit expect_output severity timeout_secs
    run=$(echo "$criteria_json" | jq -r ".[$i].run")
    expect_exit=$(echo "$criteria_json" | jq -r ".[$i].expect_exit // empty")
    expect_output=$(echo "$criteria_json" | jq -r ".[$i].expect_output // empty")
    severity=$(echo "$criteria_json" | jq -r ".[$i].severity // \"blocking\"")
    timeout_secs=$(echo "$criteria_json" | jq -r ".[$i].timeout // 60")

    local stdout_file
    stdout_file=$(mktemp)

    local actual_exit=0
    if [[ -n "$timeout_cmd" ]]; then
      $timeout_cmd "$timeout_secs" bash -c "$run" > "$stdout_file" || actual_exit=$?
    else
      bash -c "$run" > "$stdout_file" || actual_exit=$?
    fi

    local exit_ok=true
    local output_ok=true
    local is_timeout=false

    if [[ "$actual_exit" -eq 124 && -n "$timeout_cmd" ]]; then
      is_timeout=true
    fi

    if [[ -n "$expect_exit" ]]; then
      if [[ "$actual_exit" -ne "$expect_exit" ]]; then
        exit_ok=false
      fi
    fi

    if [[ -n "$expect_output" ]]; then
      if ! grep -qF "$expect_output" "$stdout_file"; then
        output_ok=false
      fi
    fi

    local status_label details=""
    if [[ "$is_timeout" == "true" ]]; then
      status_label="TIMEOUT"
      details="killed after ${timeout_secs}s [blocking]"
      has_blocking_failure=1
    elif [[ "$exit_ok" == "true" && "$output_ok" == "true" ]]; then
      status_label="PASS"
      if [[ -n "$expect_exit" ]]; then
        details="exit=$actual_exit (expected $expect_exit)"
      fi
      if [[ -n "$expect_output" ]]; then
        [[ -n "$details" ]] && details="$details, "
        details="${details}output contains \"$expect_output\""
      fi
    else
      if [[ "$severity" == "warning" ]]; then
        status_label="WARN"
      else
        status_label="FAIL"
        has_blocking_failure=1
      fi
      if [[ -n "$expect_exit" && "$exit_ok" == "false" ]]; then
        details="exit=$actual_exit (expected $expect_exit)"
      fi
      if [[ -n "$expect_output" && "$output_ok" == "false" ]]; then
        [[ -n "$details" ]] && details="$details, "
        details="${details}output missing \"$expect_output\""
      fi
      if [[ "$severity" == "warning" ]]; then
        details="$details [warning, non-blocking]"
      fi
    fi

    echo "$status_label  $scope_label criteria[$i]: \"$run\" -- $details"
    rm -f "$stdout_file"
  done

  exit "$has_blocking_failure"
}

check_review_record() {
  local plan_dir="$1" review_type="$2" review_scope="$3"

  local reviews_file="$plan_dir/reviews.json"
  if [[ ! -f "$reviews_file" ]]; then
    echo "reviews.json not found in $plan_dir"
    return 1
  fi

  local record
  record=$(jq --arg t "$review_type" --arg s "$review_scope" \
    '[.[] | select(.type == $t and .scope == $s)] | last' "$reviews_file")

  if [[ "$record" == "null" || -z "$record" ]]; then
    echo "no review record for type=$review_type scope=$review_scope"
    return 1
  fi

  local verdict remaining
  verdict=$(echo "$record" | jq -r '.verdict // "missing"')
  remaining=$(echo "$record" | jq -r '.remaining // 0')

  if [[ "$verdict" == "pass" && "$remaining" -eq 0 ]]; then
    return 0
  fi

  echo "review gate failed — type=$review_type scope=$review_scope verdict=$verdict remaining=$remaining"
  return 1
}

do_check_review() {
  local plan_json="$1" review_type="$2" review_scope="$3"
  local plan_dir
  plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"

  local result
  if ! result=$(check_review_record "$plan_dir" "$review_type" "$review_scope"); then
    echo "ERROR: $result" >&2
    exit 1
  fi
  exit 0
}

do_check_workflow() {
  local plan_json="$1"
  local plan_dir
  plan_dir="$(cd "$(dirname "$plan_json")" && pwd)"

  local json
  json=$(cat "$plan_json")

  local workflow
  workflow=$(echo "$json" | jq -r '.workflow // empty')
  if [[ -z "$workflow" ]]; then
    echo "ERROR: missing workflow field in plan.json" >&2
    exit 1
  fi

  local gate_errors=()

  local dr_result
  if ! dr_result=$(check_review_record "$plan_dir" "design-review" "design"); then
    gate_errors+=("design-review not passed: $dr_result")
  fi

  local pr_result
  if ! pr_result=$(check_review_record "$plan_dir" "plan-review" "plan"); then
    gate_errors+=("plan-review not passed: $pr_result")
  fi

  if [[ "$workflow" == "plan-only" ]]; then
    if [[ ${#gate_errors[@]} -gt 0 ]]; then
      echo "ERROR: workflow gate (plan-only) unsatisfied:" >&2
      for ge in "${gate_errors[@]}"; do echo "  - $ge" >&2; done
      exit 1
    fi
    exit 0
  fi

  local plan_status
  plan_status=$(echo "$json" | jq -r '.status')
  if [[ "$plan_status" != "Complete" ]]; then
    gate_errors+=("plan status is '$plan_status', expected 'Complete'")
  fi

  local phase_count
  phase_count=$(echo "$json" | jq '.phases | length')
  for ((p=0; p<phase_count; p++)); do
    local letter letter_lower
    letter=$(echo "$json" | jq -r ".phases[$p].letter")
    letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')
    local ir_result
    if ! ir_result=$(check_review_record "$plan_dir" "impl-review" "phase-$letter_lower"); then
      gate_errors+=("impl-review phase-$letter_lower: $ir_result")
    fi
  done

  if [[ "$phase_count" -gt 1 ]]; then
    local fr_result
    if ! fr_result=$(check_review_record "$plan_dir" "impl-review" "final"); then
      gate_errors+=("impl-review final: $fr_result")
    fi
  fi

  check_pr_exists() {
    local base="$1" head="$2" state="${3:-open}"
    local count
    if ! count=$(gh pr list --base "$base" --head "$head" --state "$state" --json number --jq 'length' 2>/dev/null); then
      return 2
    fi
    if [[ "$count" -eq 0 ]]; then
      return 1
    fi
    return 0
  }

  check_pr_with_fallback() {
    local head="$1" state="${2:-all}" error_msg="$3"
    local rc=0
    check_pr_exists "main" "$head" "$state" || rc=$?
    if [[ "$rc" -eq 2 ]]; then
      gate_errors+=("gh pr list failed — gh CLI may not be authenticated or network unavailable")
      return
    fi
    if [[ "$rc" -eq 0 ]]; then return; fi
    rc=0
    check_pr_exists "master" "$head" "$state" || rc=$?
    if [[ "$rc" -eq 2 ]]; then
      gate_errors+=("gh pr list failed — gh CLI may not be authenticated or network unavailable")
      return
    fi
    if [[ "$rc" -eq 1 ]]; then
      gate_errors+=("$error_msg")
    fi
  }

  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

  if [[ "$current_branch" == integrate/* ]]; then
    for ((p=0; p<phase_count; p++)); do
      local letter letter_lower
      letter=$(echo "$json" | jq -r ".phases[$p].letter")
      letter_lower=$(echo "$letter" | tr '[:upper:]' '[:lower:]')
      local phase_rc=0
      check_pr_exists "$current_branch" "phase-$letter_lower" "all" || phase_rc=$?
      if [[ "$phase_rc" -eq 2 ]]; then
        gate_errors+=("gh pr list failed — gh CLI may not be authenticated or network unavailable")
      elif [[ "$phase_rc" -eq 1 ]]; then
        gate_errors+=("no PR found for phase-$letter_lower → $current_branch")
      fi
    done
    check_pr_with_fallback "$current_branch" "all" "no final PR found for $current_branch → main/master"
  else
    check_pr_with_fallback "$current_branch" "all" "no PR found for $current_branch → main/master"
  fi

  if [[ "$workflow" == "pr-merge" ]]; then
    if [[ "$current_branch" == integrate/* ]]; then
      check_pr_with_fallback "$current_branch" "merged" "final PR not merged for $current_branch → main/master"
    else
      check_pr_with_fallback "$current_branch" "merged" "PR not merged for $current_branch → main/master"
    fi
  fi

  if [[ ${#gate_errors[@]} -gt 0 ]]; then
    echo "ERROR: workflow gate ($workflow) unsatisfied:" >&2
    for ge in "${gate_errors[@]}"; do echo "  - $ge" >&2; done
    exit 1
  fi
  exit 0
}

do_check_deps() {
  local plan_json="$1"
  local task_id="$2"

  local json
  json=$(cat "$plan_json")

  local phase_count
  phase_count=$(echo "$json" | jq '.phases | length')

  local deps_json=""
  for ((p=0; p<phase_count; p++)); do
    local task_count
    task_count=$(echo "$json" | jq ".phases[$p].tasks | length")
    for ((t=0; t<task_count; t++)); do
      local tid
      tid=$(echo "$json" | jq -r ".phases[$p].tasks[$t].id")
      if [[ "$tid" == "$task_id" ]]; then
        deps_json=$(echo "$json" | jq -c ".phases[$p].tasks[$t].depends_on // []")
        break 2
      fi
    done
  done

  if [[ -z "$deps_json" ]]; then
    echo "ERROR: task '$task_id' not found in plan" >&2
    exit 1
  fi

  local dep_count
  dep_count=$(echo "$deps_json" | jq 'length')
  if [[ "$dep_count" -eq 0 ]]; then
    exit 0
  fi

  for ((d=0; d<dep_count; d++)); do
    local dep_id
    dep_id=$(echo "$deps_json" | jq -r ".[$d]")
    local dep_status=""
    for ((p2=0; p2<phase_count; p2++)); do
      local tc2
      tc2=$(echo "$json" | jq ".phases[$p2].tasks | length")
      for ((t2=0; t2<tc2; t2++)); do
        local tid2
        tid2=$(echo "$json" | jq -r ".phases[$p2].tasks[$t2].id")
        if [[ "$tid2" == "$dep_id" ]]; then
          dep_status=$(echo "$json" | jq -r ".phases[$p2].tasks[$t2].status")
          break 2
        fi
      done
    done
    if [[ "$dep_status" != "complete" && "$dep_status" != "skipped" ]]; then
      echo "ERROR: dependency_not_complete: task $task_id depends on $dep_id which has status '$dep_status' (expected: complete or skipped)" >&2
      exit 1
    fi
  done

  exit 0
}

MODE=""
PLAN_JSON=""
UPDATE_TARGET=""
UPDATE_ID=""
UPDATE_STATUS=""
CHECK_REVIEW_TYPE=""
CHECK_REVIEW_SCOPE=""
# shellcheck disable=SC2034
CHECK_ENTRY_STAGE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --schema)
      MODE="schema"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --render)
      MODE="render"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --update-status)
      MODE="update-status"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --criteria)
      MODE="criteria"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --task)
      shift
      UPDATE_TARGET="task"
      if [[ $# -gt 0 ]]; then
        UPDATE_ID="$1"
        shift
      fi
      ;;
    --phase)
      shift
      UPDATE_TARGET="phase"
      if [[ $# -gt 0 ]]; then
        UPDATE_ID="$1"
        shift
      fi
      ;;
    --plan)
      UPDATE_TARGET="plan"
      shift
      ;;
    --status)
      shift
      if [[ $# -gt 0 ]]; then
        UPDATE_STATUS="$1"
        shift
      fi
      ;;
    --check-review)
      MODE="check-review"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --check-workflow)
      MODE="check-workflow"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --consistency)
      MODE="consistency"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --check-entry)
      MODE="check-entry"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --check-base)
      MODE="check-base"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --check-deps)
      MODE="check-deps"
      shift
      if [[ $# -gt 0 ]]; then
        PLAN_JSON="$1"
        shift
      fi
      ;;
    --stage)
      shift
      if [[ $# -gt 0 ]]; then
        CHECK_ENTRY_STAGE="$1"
        shift
      fi
      ;;
    --type)
      shift
      if [[ $# -gt 0 ]]; then
        CHECK_REVIEW_TYPE="$1"
        shift
      fi
      ;;
    --scope)
      shift
      if [[ $# -gt 0 ]]; then
        CHECK_REVIEW_SCOPE="$1"
        shift
      fi
      ;;
    *)
      usage
      ;;
  esac
done

[[ -z "$MODE" ]] && usage
[[ -z "$PLAN_JSON" ]] && usage

case "$MODE" in
  schema) do_schema "$PLAN_JSON" ;;
  render) do_render "$PLAN_JSON" ;;
  update-status)
    case "$UPDATE_TARGET" in
      task) do_update_status_task "$PLAN_JSON" "$UPDATE_ID" "$UPDATE_STATUS" ;;
      phase) do_update_status_phase "$PLAN_JSON" "$UPDATE_ID" "$UPDATE_STATUS" ;;
      plan) do_update_status_plan "$PLAN_JSON" "$UPDATE_STATUS" ;;
      *) usage ;;
    esac
    ;;
  criteria)
    case "$UPDATE_TARGET" in
      task) do_criteria "$PLAN_JSON" "task" "$UPDATE_ID" ;;
      phase) do_criteria "$PLAN_JSON" "phase" "$UPDATE_ID" ;;
      plan) do_criteria "$PLAN_JSON" "plan" ;;
      *) echo "ERROR: --criteria requires --task <ID>, --phase <LETTER>, or --plan" >&2; exit 2 ;;
    esac
    ;;
  check-review)
    if [[ -z "$CHECK_REVIEW_TYPE" || -z "$CHECK_REVIEW_SCOPE" ]]; then
      echo "ERROR: --check-review requires --type <TYPE> and --scope <SCOPE>" >&2
      exit 2
    fi
    do_check_review "$PLAN_JSON" "$CHECK_REVIEW_TYPE" "$CHECK_REVIEW_SCOPE"
    ;;
  consistency) do_consistency "$PLAN_JSON" || exit 1 ;;
  check-entry)
    if [[ -z "$CHECK_ENTRY_STAGE" ]]; then
      echo "ERROR: --check-entry requires --stage <STAGE>" >&2
      exit 2
    fi
    do_check_entry "$PLAN_JSON" "$CHECK_ENTRY_STAGE"
    ;;
  check-base) do_check_base "$PLAN_JSON" ;;
  check-workflow) do_check_workflow "$PLAN_JSON" ;;
  check-deps)
    if [[ "$UPDATE_TARGET" != "task" || -z "$UPDATE_ID" ]]; then
      echo "ERROR: --check-deps requires --task <ID>" >&2
      exit 2
    fi
    do_check_deps "$PLAN_JSON" "$UPDATE_ID"
    ;;
  *) usage ;;
esac
